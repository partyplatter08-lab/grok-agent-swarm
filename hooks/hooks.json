{
  "description": "Agent Swarm: seamless effort→mode with deferred switch while multi-agent work finishes",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${GROK_PLUGIN_ROOT}/scripts/ensure_swarm_effort.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${GROK_PLUGIN_ROOT}/scripts/inject_mode.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${GROK_PLUGIN_ROOT}/scripts/on_stop.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
